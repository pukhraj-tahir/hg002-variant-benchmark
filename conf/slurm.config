def CONT = "/hdd4/sines/specialtopicsinbioinformatics/pukhraj.sines/hg002_variant_pipeline/containers"

process {

    withName: 'CLAIR3' {
        container      = "${CONT}/clair3_latest.sif"
        cpus           = 16
        memory         = '32 GB'
        time           = '24h'
        queue          = 'gpu'
        clusterOptions = '--gres=gpu:v100:1'
    }

    withName: 'DEEPVARIANT' {
        container      = "${CONT}/deepvariant_1.6.0.sif"
        cpus           = 16
        memory         = '64 GB'
        time           = '24h'
        queue          = 'gpu'
        clusterOptions = '--gres=gpu:v100:1'
    }

    withName: 'HAPPY' {
        container      = "${CONT}/hap.py_latest.sif"
        cpus           = 8
        memory         = '32 GB'
        time           = '4h'
        queue          = 'gpu'
        clusterOptions = '--gres=gpu:0'
    }
}
