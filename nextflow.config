nextflow.enable.dsl = 2

def BASE = "/hdd4/sines/specialtopicsinbioinformatics/pukhraj.sines/hg002_variant_pipeline"
def CONT = "${BASE}/containers"

params {
    bam          = "${BASE}/data/hg002_subset.sorted.bam"
    ref          = "${BASE}/data/GRCh38.primary_assembly.genome.fa"
    truth_vcf    = "${BASE}/benchmark/truth/HG002_GRCh38_1_22_v4.2.1_benchmark.vcf.gz"
    truth_bed    = "${BASE}/benchmark/truth/HG002_GRCh38_1_22_v4.2.1_benchmark_noinconsistent.bed"
    clair3_model = "/opt/models/hifi"
    outdir       = "${BASE}/results/nextflow"
}

singularity {
    enabled    = true
    autoMounts = true
    runOptions = "--nv"
}

profiles {
    slurm { process.executor = 'slurm' }
    local { process.executor = 'local' }
}

// Redirect all Nextflow work files OFF your home quota
workDir = "${BASE}/nf_work"

includeConfig 'conf/slurm.config'
